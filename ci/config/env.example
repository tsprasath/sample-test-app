# ═══════════════════════════════════════════════════════════════════
# AI DevOps — Required Environment Variables for JCasC
# ═══════════════════════════════════════════════════════════════════
# These feed into ci/config/jenkins.yml via ${VAR} interpolation.
# Copy to .env, fill in real values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── Jenkins Admin ─────────────────────────────────────────────────
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=changeme-use-a-strong-password

# ── OCI / Registry ───────────────────────────────────────────────
OCI_REGION=ap-mumbai-1
OCIR_URL=bom.ocir.io
OCIR_NAMESPACE=diksha
PROJECT_NAME=diksha-dev
OCIR_USERNAME=<tenancy-namespace>/oracleidentitycloudservice/<email>
OCIR_PASSWORD=<auth-token-from-oci-console>

# ── GitHub ───────────────────────────────────────────────────────
GIT_USERNAME=jenkins
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHARED_LIB_REPO=https://github.com/tsprasath/ai-devops.git

# ── GitOps ───────────────────────────────────────────────────────
GITOPS_REPO=https://github.com/tsprasath/ai-devops.git
GITOPS_BRANCH=main

# ── App Repos (source code) ──────────────────────────────────────
AUTH_SERVICE_REPO=https://github.com/tsprasath/sample-test-app.git
# Add more as you onboard services:
# FRONTEND_REPO=https://github.com/tsprasath/frontend.git

# ── OKE (Kubernetes Cloud Agent) ─────────────────────────────────
OKE_API_SERVER=https://xxx.oraclecloud.com:6443
JENKINS_AGENT_NAMESPACE=jenkins
JENKINS_SA=jenkins-agent
JENKINS_URL=http://jenkins.jenkins.svc.cluster.local:8080
JENKINS_TUNNEL=jenkins-agent.jenkins.svc.cluster.local:50000
# Base64-encoded kubeconfig: cat kubeconfig | base64 -w0
OKE_KUBECONFIG_B64=<base64-encoded-kubeconfig>

# ── Notifications ────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#ci-cd-notifications
SLACK_CHANNEL_ALERTS=#ci-cd-alerts

# ── SonarQube (optional) ─────────────────────────────────────────
SONAR_TOKEN=

# ── Trivy defaults ───────────────────────────────────────────────
TRIVY_SEVERITY=CRITICAL,HIGH
TRIVY_HIGH_THRESHOLD=5
