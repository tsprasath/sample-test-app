// =============================================================================
// Jenkinsfile — Split-Repo GitOps Pipeline
// =============================================================================
// This pipeline is TRIGGERED BY THE APP REPO (e.g., auth-service).
// It builds the image from the app repo, pushes to OCIR, then updates
// the image tag in THIS devops repo (ai-devops) for ArgoCD to deploy.
//
// Flow:
//   App repo push → Jenkins webhook → this pipeline
//   → build & test (from app repo)
//   → push image to OCIR
//   → update values-dev.yaml in devops repo (gitopsUpdate)
//   → ArgoCD detects change → deploys to cluster
//   → promote to staging/prod (manual gates)
//
// Requires:
//   - Jenkins shared library 'diksha-dev-lib' (ci/shared-lib)
//   - Credentials: ocir-credentials, git-credentials
//   - K8s cloud configured (OKE cluster)
//   - Parameters: APP_REPO_URL, SERVICE_NAME, SERVICE_DIR
// =============================================================================

@Library('diksha-dev-lib') _

import org.dev.Constants

pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins: worker
spec:
  serviceAccountName: jenkins
  containers:
  - name: docker
    image: docker:24-dind
    securityContext:
      privileged: true
    volumeMounts:
    - name: docker-graph
      mountPath: /var/lib/docker
    resources:
      requests: { cpu: "500m", memory: "1Gi" }
      limits:   { cpu: "2",    memory: "4Gi" }
  - name: node
    image: node:20-alpine
    command: ['sleep']
    args: ['infinity']
    resources:
      requests: { cpu: "250m", memory: "512Mi" }
  - name: trivy
    image: aquasec/trivy:latest
    command: ['sleep']
    args: ['infinity']
  - name: gitleaks
    image: zricethezav/gitleaks:latest
    command: ['sleep']
    args: ['infinity']
  - name: helm
    image: alpine/helm:3.14.0
    command: ['sleep']
    args: ['infinity']
  - name: yq
    image: mikefarah/yq:4
    command: ['sleep']
    args: ['infinity']
  volumes:
  - name: docker-graph
    emptyDir: {}
'''
        }
    }

    // ── Pipeline Parameters ─────────────────────────────────────────
    // These allow ONE pipeline to build ANY service from ANY app repo.
    // JCasC jobs.groovy pre-configures these per service.
    parameters {
        string(name: 'APP_REPO_URL',
               defaultValue: 'https://github.com/tsprasath/sample-test-app.git',
               description: 'Application source code repository URL')
        string(name: 'APP_REPO_BRANCH',
               defaultValue: 'main',
               description: 'Branch to build from')
        string(name: 'SERVICE_NAME',
               defaultValue: 'auth-service',
               description: 'Service name (matches Helm chart dir in devops repo)')
        string(name: 'SERVICE_DIR',
               defaultValue: '.',
               description: 'Path to service root in app repo (Dockerfile location)')
    }

    environment {
        // ── From JCasC global env vars ──
        OCI_REGION   = Constants.OCI_REGION
        OCIR_URL     = Constants.OCIR_URL
        OCIR_NS      = Constants.OCIR_NAMESPACE
        PROJECT      = Constants.PROJECT_NAME
        OCIR_CRED_ID = Constants.OCIR_CREDENTIALS_ID

        // ── Derived ──
        IMAGE_NAME   = "${OCIR_URL}/${OCIR_NS}/${PROJECT}/${params.SERVICE_NAME}"
        IMAGE_TAG    = ''  // Set in Checkout stage
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
        ansiColor('xterm')
    }

    stages {
        // =====================================================================
        // 1. CHECKOUT APP REPO (source code lives here)
        // =====================================================================
        stage('Checkout App') {
            steps {
                // Clean workspace and clone the APP repo (not devops repo)
                dir('app') {
                    git branch: params.APP_REPO_BRANCH,
                        credentialsId: 'git-credentials',
                        url: params.APP_REPO_URL

                    script {
                        env.GIT_SHA = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                        env.IMAGE_TAG = "${env.GIT_SHA}-${BUILD_NUMBER}"
                        echo "════════════════════════════════════════════"
                        echo "Building: ${IMAGE_NAME}:${IMAGE_TAG}"
                        echo "Service:  ${params.SERVICE_NAME}"
                        echo "App repo: ${params.APP_REPO_URL}"
                        echo "Commit:   ${env.GIT_SHA}"
                        echo "════════════════════════════════════════════"
                    }
                }
            }
        }

        // =====================================================================
        // 2. CODE QUALITY
        // =====================================================================
        stage('Code Quality') {
            steps {
                container('node') {
                    dir("app/${params.SERVICE_DIR}") {
                        codeQualityScan(
                            reportDir: 'code-quality-reports',
                            failOnAudit: false,
                            auditLevel: 'critical'
                        )
                    }
                }
            }
        }

        // =====================================================================
        // 3. UNIT TESTS
        // =====================================================================
        stage('Unit Tests') {
            steps {
                container('node') {
                    dir("app/${params.SERVICE_DIR}") {
                        sh 'npm ci --no-audit'
                        sh 'npx jest --forceExit --detectOpenHandles --coverage --ci --reporters=default --reporters=jest-junit'
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "app/${params.SERVICE_DIR}/junit.xml"
                }
            }
        }

        // =====================================================================
        // 4. SECURITY SCANS (parallel)
        // =====================================================================
        stage('Security Scans') {
            parallel {
                stage('Secret Detection') {
                    steps {
                        container('gitleaks') {
                            dir('app') {
                                gitleaksScan(
                                    reportDir: 'gitleaks-reports',
                                    failOnFindings: true
                                )
                            }
                        }
                    }
                }
                stage('Trivy Filesystem') {
                    steps {
                        container('trivy') {
                            dir("app/${params.SERVICE_DIR}") {
                                trivyScan(
                                    scanFilesystem: true,
                                    failOnCritical: true,
                                    reportDir: 'trivy-reports'
                                )
                            }
                        }
                    }
                }
            }
        }

        // =====================================================================
        // 5. DOCKER BUILD + PUSH TO OCIR
        // =====================================================================
        stage('Build & Push') {
            when {
                anyOf {
                    expression { params.APP_REPO_BRANCH == 'main' }
                    expression { params.APP_REPO_BRANCH == 'develop' }
                    expression { params.APP_REPO_BRANCH ==~ /release\/.*/ }
                }
            }
            steps {
                container('docker') {
                    dir("app/${params.SERVICE_DIR}") {
                        buildAndPush(
                            imageName: "${PROJECT}/${params.SERVICE_NAME}",
                            imageTag: "${IMAGE_TAG}",
                            registry: "${OCIR_URL}/${OCIR_NS}",
                            credentialsId: "${OCIR_CRED_ID}"
                        )
                    }
                }
            }
        }

        // =====================================================================
        // 6. TRIVY IMAGE SCAN (post-build)
        // =====================================================================
        stage('Image Scan') {
            when {
                expression { params.APP_REPO_BRANCH == 'main' }
            }
            steps {
                container('trivy') {
                    trivyScan(
                        image: "${IMAGE_NAME}:${IMAGE_TAG}",
                        failOnCritical: true,
                        failOnHigh: false,
                        reportDir: 'trivy-reports'
                    )
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-reports/**', allowEmptyArchive: true
                }
            }
        }

        // =====================================================================
        // 7. HELM VALIDATE (validate chart from devops repo)
        // =====================================================================
        stage('Helm Validate') {
            when {
                expression { params.APP_REPO_BRANCH == 'main' }
            }
            steps {
                container('helm') {
                    // Checkout devops repo to validate helm chart
                    dir('devops') {
                        git branch: 'main',
                            credentialsId: 'git-credentials',
                            url: env.GITOPS_REPO ?: 'https://github.com/tsprasath/ai-devops.git'
                    }
                    helmLint(
                        chartPath: "devops/infra/helm-charts/${params.SERVICE_NAME}",
                        strict: true,
                        kubeVersion: '1.28.0',
                        reportDir: 'helm-reports'
                    )
                }
            }
        }

        // =====================================================================
        // 8. DEPLOY TO DEV (update devops repo → ArgoCD syncs)
        // =====================================================================
        stage('Deploy to Dev') {
            when {
                expression { params.APP_REPO_BRANCH == 'main' }
            }
            steps {
                container('yq') {
                    gitopsUpdate(
                        service: params.SERVICE_NAME,
                        imageTag: "${IMAGE_TAG}",
                        targetEnv: 'dev'
                    )
                }
            }
        }

        // =====================================================================
        // 9. SMOKE TEST DEV
        // =====================================================================
        stage('Smoke Test Dev') {
            when {
                expression { params.APP_REPO_BRANCH == 'main' }
            }
            steps {
                script {
                    echo "Waiting for ArgoCD sync..."
                    sleep(time: 30, unit: 'SECONDS')

                    def healthUrl = "https://dev-api.diksha.gov.in/${params.SERVICE_NAME}/health"
                    def retries = 5
                    def success = false

                    for (int i = 0; i < retries; i++) {
                        def status = sh(
                            script: "curl -sf -o /dev/null -w '%{http_code}' ${healthUrl} || echo '000'",
                            returnStdout: true
                        ).trim()
                        if (status == '200') {
                            success = true
                            echo "Health check passed on attempt ${i + 1}"
                            break
                        }
                        echo "Attempt ${i + 1}/${retries}: got ${status}, retrying in 10s..."
                        sleep(time: 10, unit: 'SECONDS')
                    }

                    if (!success) {
                        unstable("Dev smoke test failed after ${retries} attempts")
                    }
                }
            }
        }

        // =====================================================================
        // 10. PROMOTE TO STAGING
        // =====================================================================
        stage('Promote to Staging') {
            when {
                expression { params.APP_REPO_BRANCH == 'main' }
            }
            steps {
                container('yq') {
                    gitopsUpdate(
                        service: params.SERVICE_NAME,
                        imageTag: "${IMAGE_TAG}",
                        targetEnv: 'staging'
                    )
                }
            }
        }

        // =====================================================================
        // 11. PROMOTE TO PROD (manual approval)
        // =====================================================================
        stage('Promote to Prod') {
            when {
                expression { params.APP_REPO_BRANCH == 'main' }
            }
            steps {
                container('yq') {
                    promoteToProd(
                        service: params.SERVICE_NAME,
                        imageTag: "${IMAGE_TAG}",
                        fromEnv: 'staging',
                        toEnv: 'prod',
                        smokeTestUrl: "https://staging-api.diksha.gov.in/${params.SERVICE_NAME}",
                        approvers: 'prasath,admin',
                        timeoutMinutes: 60
                    )
                }
            }
        }
    }

    // =========================================================================
    // POST ACTIONS
    // =========================================================================
    post {
        success {
            notifyTeam(
                status: 'SUCCESS',
                channel: '#dev-builds'
            )
        }
        failure {
            notifyTeam(
                status: 'FAILURE',
                channel: '#dev-alerts'
            )
        }
        unstable {
            notifyTeam(
                status: 'UNSTABLE',
                channel: '#dev-alerts'
            )
        }
        always {
            cleanWs()
        }
    }
}
