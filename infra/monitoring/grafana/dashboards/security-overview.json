{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Security Overview", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Open CVEs - Critical",
      "type": "stat",
      "targets": [{ "expr": "sum(trivy_vulnerability_count{severity=\"critical\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Open CVEs - High",
      "type": "stat",
      "targets": [{ "expr": "sum(trivy_vulnerability_count{severity=\"high\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Open CVEs - Medium",
      "type": "stat",
      "targets": [{ "expr": "sum(trivy_vulnerability_count{severity=\"medium\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Failed Security Scans",
      "type": "stat",
      "targets": [{ "expr": "sum(security_scan_status{status=\"failed\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "WAF Blocks Today",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(waf_blocked_requests_total[24h]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Auth Failures (24h)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(auth_failure_total[24h]))", "refId": "A" }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 101, "title": "Trends", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "pointSize": 5, "showPoints": "never" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Vulnerability Trend",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (severity) (trivy_vulnerability_count)", "legendFormat": "{{severity}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "pointSize": 5, "showPoints": "never" }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "WAF Blocks Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(waf_blocked_requests_total[5m]))", "legendFormat": "Blocked requests/s", "refId": "A" }
      ]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 102, "title": "Scan Results", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 9,
      "options": { "footer": { "enablePagination": true }, "showHeader": true },
      "title": "Latest Scan Results",
      "type": "table",
      "targets": [
        { "expr": "trivy_vulnerability_count", "format": "table", "instant": true, "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "includeByName": { "image": true, "severity": true, "Value": true, "Time": true }, "renameByName": { "Value": "count", "Time": "scan_date" } } }
      ]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 103, "title": "Security Events Log", "type": "row" },
    {
      "datasource": { "type": "loki", "uid": "$loki_datasource" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 10,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "title": "Security Events",
      "type": "logs",
      "targets": [
        { "expr": "{job=\"security\"} |= \"\" | logfmt | level=~\"warn|error|critical\"", "refId": "A" }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["security", "vulnerability", "waf"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource" },
      { "current": {}, "hide": 0, "includeAll": false, "label": "Loki", "multi": false, "name": "loki_datasource", "options": [], "query": "loki", "refresh": 1, "type": "datasource" }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Security Overview",
  "uid": "security-overview",
  "version": 1
}
