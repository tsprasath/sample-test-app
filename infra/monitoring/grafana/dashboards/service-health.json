{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Overview", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "reqps" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total Requests/sec",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=~\"$namespace\", service=~\"$service\"}[5m]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }, "unit": "percent", "max": 100, "min": 0 } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Error Rate %",
      "type": "stat",
      "targets": [{ "expr": "100 * sum(rate(http_requests_total{namespace=~\"$namespace\", service=~\"$service\", code=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=~\"$namespace\", service=~\"$service\"}[5m]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }, "unit": "s" } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "P99 Latency",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=~\"$namespace\", service=~\"$service\"}[5m])) by (le))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Active Pods",
      "type": "stat",
      "targets": [{ "expr": "sum(kube_pod_info{namespace=~\"$namespace\"})", "refId": "A" }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 101, "title": "Request & Error Rates", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Request Rate by Service",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (service) (rate(http_requests_total{namespace=~\"$namespace\", service=~\"$service\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Error Rate by Service",
      "type": "timeseries",
      "targets": [{ "expr": "100 * sum by (service) (rate(http_requests_total{namespace=~\"$namespace\", service=~\"$service\", code=~\"5..\"}[5m])) / sum by (service) (rate(http_requests_total{namespace=~\"$namespace\", service=~\"$service\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 102, "title": "Latency", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Latency Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=~\"$namespace\", service=~\"$service\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=~\"$namespace\", service=~\"$service\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=~\"$namespace\", service=~\"$service\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 103, "title": "Request Duration Distribution", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "color": { "mode": "scheme", "schemeMode": "Spectral" }, "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } } } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 8,
      "options": { "calculate": false, "cellGap": 1, "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "scheme": "Spectral", "steps": 64 }, "exemplars": { "color": "rgba(255,0,255,0.7)" }, "filterValues": { "le": 1e-9 }, "tooltip": { "show": true, "yHistogram": false }, "yAxis": { "axisPlacement": "left", "unit": "s" } },
      "title": "Request Duration Distribution",
      "type": "heatmap",
      "targets": [{ "expr": "sum(increase(http_request_duration_seconds_bucket{namespace=~\"$namespace\", service=~\"$service\"}[5m])) by (le)", "format": "heatmap", "legendFormat": "{{le}}", "refId": "A" }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }, "id": 104, "title": "Pod Status", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "restarts" }, "properties": [{ "id": "custom.displayMode", "value": "color-text" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 3 }] } }] },
          { "matcher": { "id": "byName", "options": "cpu" }, "properties": [{ "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "memory" }, "properties": [{ "id": "unit", "value": "bytes" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "id": 9,
      "options": { "footer": { "enablePagination": true }, "showHeader": true },
      "title": "Pod Status",
      "type": "table",
      "targets": [
        { "expr": "kube_pod_info{namespace=~\"$namespace\"}", "format": "table", "instant": true, "refId": "A" },
        { "expr": "sum by (pod) (kube_pod_container_status_restarts_total{namespace=~\"$namespace\"})", "format": "table", "instant": true, "refId": "B" },
        { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\"}[5m]))", "format": "table", "instant": true, "refId": "C" },
        { "expr": "sum by (pod) (container_memory_usage_bytes{namespace=~\"$namespace\"})", "format": "table", "instant": true, "refId": "D" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "includeByName": { "pod": true, "phase": true, "Value #B": true, "Value #C": true, "Value #D": true, "created_by_name": true }, "renameByName": { "Value #B": "restarts", "Value #C": "cpu", "Value #D": "memory", "phase": "status", "created_by_name": "owner" } } }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["service-health", "sre", "golden-signals"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource" },
      { "allValue": ".*", "current": {}, "datasource": { "type": "prometheus", "uid": "$datasource" }, "definition": "label_values(http_requests_total, namespace)", "hide": 0, "includeAll": true, "label": "Namespace", "multi": true, "name": "namespace", "query": { "query": "label_values(http_requests_total, namespace)" }, "refresh": 2, "sort": 1, "type": "query" },
      { "allValue": ".*", "current": {}, "datasource": { "type": "prometheus", "uid": "$datasource" }, "definition": "label_values(http_requests_total{namespace=~\"$namespace\"}, service)", "hide": 0, "includeAll": true, "label": "Service", "multi": true, "name": "service", "query": { "query": "label_values(http_requests_total{namespace=~\"$namespace\"}, service)" }, "refresh": 2, "sort": 1, "type": "query" }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Service Health",
  "uid": "service-health",
  "version": 1
}
